// =============================================================================
// CGIL ISOLATED TEST 04: Sigils and Typed State Machines
// =============================================================================

pact <stdio.h>;

conjure spell putchar(mark32 c) -> mark32;

// --- Print Helpers ---
spell print(scroll msg) -> abyss {
    fore (mark16 i = 0; i < msg.len; i = i + 1) {
        putchar(msg.ptr[i]);
    }
}

spell print_ok(scroll label) -> abyss {
    print(label);
    print(" ... OK\n");
}

// --- The Sigil (Hardware State Machine) ---
sigil Engine {
    stance Cold;
    stance Ignited;
    stance Overheated;

    mark16 fuel_level;
    mark16 temperature;
}

// --- State Machine Spells ---

// Takes a Cold engine and transitions it to Ignited.
spell ignite(sigil* Engine:Cold ctrl) -> abyss {
    ctrl->temperature = 100;
    ctrl = Engine:Ignited; // The State Transition!
}

// Takes an Ignited engine, burns fuel, increases temp.
spell rev(sigil* Engine:Ignited ctrl) -> abyss {
    ctrl->fuel_level = ctrl->fuel_level - 10;
    ctrl->temperature = ctrl->temperature + 50;

    if (ctrl->temperature > 200) {
        ctrl = Engine:Overheated; // Blown engine
    }
}

// --- The Test ---
spell test_sigils() -> abyss {
    
    // 1. Initialization with a specific starting stance
    sigil Engine v8 = Engine:Cold { fuel_level: 100, temperature: 20 };
    mark16 init_temp = v8.temperature;

    // 2. Pass to a spell that requires Engine:Cold
    ignite(&v8);
    v8 = Engine:Ignited;
    mark16 ignited_temp = v8.temperature;

    // 3. Pass to a spell that requires Engine:Ignited
    rev(&v8);
    mark16 rev1_fuel = v8.fuel_level;

    rev(&v8); 
    mark16 rev2_temp = v8.temperature; // Temp should now be 200
    v8 = Engine:Overheated;

    // Validation
    if (init_temp == 20) {
        if (ignited_temp == 100) {
            if (rev1_fuel == 90) {
                if (rev2_temp == 200) {
                    print_ok("TEST 04: Sigils, Stances, and State Transitions");
                }
            }
        }
    }
}

// --- Entry Point ---
spell main() -> mark16 {
    print("\nRunning Test 04...\n");
    test_sigils();
    yield 0;
}