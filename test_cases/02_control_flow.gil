// =============================================================================
// CGIL ISOLATED TEST 02: Control Flow
// =============================================================================

pact <stdio.h>;

conjure spell putchar(mark32 c) -> mark32;

// --- Print Helpers ---
spell print(scroll msg) -> abyss {
    fore (mark16 i = 0; i < msg.len; i = i + 1) {
        putchar(msg.ptr[i]);
    }
}

spell print_ok(scroll label) -> abyss {
    print(label);
    print(" ... OK\n");
}

// --- The Test ---
spell test_control_flow() -> abyss {
    // 1. If / Elif / Else
    mark16 branch_val = 0;
    mark16 target = 2;

    if (target == 0) {
        branch_val = 10;
    } elif (target == 1) {
        branch_val = 20;
    } elif (target == 2) {
        branch_val = 30; // Should hit this
    } else {
        branch_val = 40;
    }

    // 2. Whirl Loop (While)
    mark16 w_count = 0;
    whirl (w_count < 5) {
        w_count = w_count + 1;
    }

    // 3. Fore Loop with Surge (Continue)
    mark16 s_count = 0;
    fore (mark16 i = 0; i < 5; i = i + 1) {
        if (i == 2) {
            surge; // Skip adding when i is 2
        }
        s_count = s_count + 1;
    }

    // 4. Fore Loop with Shatter (Break)
    mark16 b_count = 0;
    fore (mark16 i = 0; i < 100; i = i + 1) {
        if (i == 7) {
            shatter; // Break early
        }
        b_count = b_count + 1;
    }

    // Validation
    if (branch_val == 30) {
        if (w_count == 5) {
            if (s_count == 4) { // Loop ran 5 times, but skipped 1 addition
                if (b_count == 7) { // Broke before adding the 8th time
                    print_ok("TEST 02: Control Flow (Branches, Loops, Shatter, Surge)");
                }
            }
        }
    }
}

// --- Entry Point ---
spell main() -> mark16 {
    print("\nRunning Test 02...\n");
    test_control_flow();
    yield 0;
}