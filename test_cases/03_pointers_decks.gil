// =============================================================================
// CGIL ISOLATED TEST 03: Pointers, References, and Array Decks
// =============================================================================

pact <stdio.h>;

conjure spell putchar(mark32 c) -> mark32;

// --- Print Helpers ---
spell print(scroll msg) -> abyss {
    fore (mark16 i = 0; i < msg.len; i = i + 1) {
        putchar(msg.ptr[i]);
    }
}

spell print_ok(scroll label) -> abyss {
    print(label);
    print(" ... OK\n");
}

// --- Mutation Helper Spell ---
// Takes a pointer to a mark16 and modifies the original value in memory.
spell mutate_value(mark16* target_ptr) -> abyss {
    *target_ptr = 999;
}

// --- The Test ---
spell test_memory() -> abyss {
    
    // 1. Array (Deck) Allocation and Indexing
    deck[5] mark16 numbers;
    numbers[0] = 10;
    numbers[1] = 20;
    numbers[2] = 30;
    
    mark16 deck_sum = numbers[0] + numbers[2]; // Should be 40

    // 2. Address-Of and Pointer Dereferencing
    mark16 secret = 100;
    mark16* secret_ptr = &secret;
    
    // Mutate the variable through its pointer
    *secret_ptr = 500; 

    // 3. Passing Pointers to Spells
    mark16 external_val = 0;
    mutate_value(&external_val);

    // Validation
    if (deck_sum == 40) {
        if (secret == 500) { // Validates *secret_ptr worked
            if (external_val == 999) { // Validates spell pointer passing worked
                print_ok("TEST 03: Pointers, Memory, and Decks");
            }
        }
    }
}

// --- Entry Point ---
spell main() -> mark16 {
    print("\nRunning Test 03...\n");
    test_memory();
    yield 0;
}