// =============================================================================
// CGIL BOOTSTRAP: TEST 09 - THE ZERO-COPY LEXER
// =============================================================================

pact <stdio.h>;
conjure spell putchar(mark32 c) -> mark32;

// --- Helpers ---
spell print(scroll msg) -> abyss {
    fore (mark16 i = 0; i < msg.len; i = i + 1) {
        putchar(msg.ptr[i]);
    }
}

// --- The Architecture ---
rank TokenKind {
    Identifier, 
    Number, 
    Assign, 
    Plus, 
    Semi, 
    EndOfFile
}

// THE FIX: Define an error rank for the lexer
rank LexerError {
    UnexpectedChar
}

sigil Token {
    stance Valid;
    TokenKind kind;
    mark16 start;
    mark16 length;
}

sigil Lexer {
    stance Active;
    stance EOF;
    scroll source;
    mark16 pos;
}

// --- Classifiers ---
spell is_digit(rune c) -> oath {
    if (c >= 48 && c <= 57) { yield kept; }
    yield forsaken;
}

spell is_alpha(rune c) -> oath {
    if ((c >= 65 && c <= 90) || (c >= 97 && c <= 122) || c == 95) { yield kept; }
    yield forsaken;
}

// --- The Core Scanner Engine ---
// THE FIX: The spell now returns an Omen: Token | ruin<LexerError>
spell next_token(own sigil* Lexer:Active lex) -> (sigil* Lexer, Token | ruin<LexerError>) {
    
    // 1. Skip Whitespace
    whirl (lex->pos < lex->source.len) {
        rune c = lex->source.ptr[lex->pos];
        if (c == 32 || c == 10 || c == 13 || c == 9) {
            lex->pos = lex->pos + 1;
        } else {
            shatter;
        }
    }

    // 2. Check EOF
    if (lex->pos >= lex->source.len) {
        lex = Lexer:EOF;
        Token t = Token:Valid { kind: TokenKind::EndOfFile, start: lex->pos, length: 0 };
        yield (lex, t);
    }

    mark16 start_pos = lex->pos;
    rune c = lex->source.ptr[lex->pos];

    // 3. Scan Number Literal
    if (is_digit(c) == kept) {
        whirl (lex->pos < lex->source.len) {
            if (is_digit(lex->source.ptr[lex->pos]) == kept) {
                lex->pos = lex->pos + 1;
            } else {
                shatter;
            }
        }
        Token t = Token:Valid { kind: TokenKind::Number, start: start_pos, length: lex->pos - start_pos };
        yield (lex, t);
    }

    // 4. Scan Identifier
    if (is_alpha(c) == kept) {
        whirl (lex->pos < lex->source.len) {
            rune peek_c = lex->source.ptr[lex->pos];
            if (is_alpha(peek_c) == kept || is_digit(peek_c) == kept) {
                lex->pos = lex->pos + 1;
            } else {
                shatter;
            }
        }
        Token t = Token:Valid { kind: TokenKind::Identifier, start: start_pos, length: lex->pos - start_pos };
        yield (lex, t);
    }

    // 5. Scan Single-Character Symbols
    lex->pos = lex->pos + 1;
    
    if (c == 61) { 
        Token t = Token:Valid { kind: TokenKind::Assign, start: start_pos, length: 1 }; 
        yield (lex, t);
    } 
    if (c == 43) { 
        Token t = Token:Valid { kind: TokenKind::Plus, start: start_pos, length: 1 }; 
        yield (lex, t);
    }   
    if (c == 59) { 
        Token t = Token:Valid { kind: TokenKind::Semi, start: start_pos, length: 1 }; 
        yield (lex, t);
    }   
    
    // THE FIX: If it's none of the above, yield a ruin to trigger the divine error path
    yield (lex, ruin(LexerError::UnexpectedChar));
}

// --- The Test Runner ---
spell main() -> mark16 {
    scroll code = "val = 42 + 5;";
    print("\n[SYSTEM] Bootstrapping Lexer. Scanning: \""); print(code); print("\"\n\n");

    sigil Lexer lex = Lexer:Active { source: code, pos: 0 };
    mark16 scanning = 1;

    whirl (scanning == 1) {
        lex <~ divine next_token(own &lex) {
            
            // Success branch
            (ctrl, Token t) => {
                print("Token -> Kind: "); 
                putchar(t.kind + 48); 
                print(" | Start: ");
                if (t.start < 10) { putchar(t.start + 48); } else { print("10+"); }
                print(" | Length: ");
                putchar(t.length + 48);
                print("\n");
                
                if (t.kind == TokenKind::EndOfFile) {
                    scanning = 0;
                }
            }
            
            // THE FIX: Catch-all error branch for the unexpected character ruin
            (ctrl, ruin err) => {
                print("\n[FATAL] Lexer encountered an unexpected character!\n");
                scanning = 0;
            }
        }
    }
    
    lex = Lexer:EOF;
    
    print("\n[SYSTEM] Stage 1 Lexer successfully parsed the stream.\n");
    yield 0;
}