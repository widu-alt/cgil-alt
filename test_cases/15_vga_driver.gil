// =============================================================================
// CGIL ISOLATED TEST 15: Ring 0 Bare Metal VGA Driver
// =============================================================================

spell main() -> mark16 {
    // 1. Forge a raw hardware pointer directly to the VGA text buffer.
    // In a normal language, this is highly illegal. In Cgil, we cast the 
    // raw physical address (0xB8000) directly into a mutable pointer.
    mark16* vga = cast<mark16*>(0xB8000);

    // 2. Define our colors.
    // 0x0A is Light Green. We shift it left by 8 bits (multiplying by 256)
    // 0x0A * 256 = 2560. This puts the color code in the upper 8 bits.
    mark16 color = 2560; 

    // 3. Blast "CGIL" directly into physical video memory.
    // C = ASCII 67
    // G = ASCII 71
    // I = ASCII 73
    // L = ASCII 76
    
    vga[0] = color + 67;
    vga[1] = color + 71;
    vga[2] = color + 73;
    vga[3] = color + 76;

    yield 0;
}