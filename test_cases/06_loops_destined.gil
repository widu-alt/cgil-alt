// =============================================================================
// CGIL ISOLATED TEST 06: Loop Control and Destined Cleanups
// =============================================================================

pact <stdio.h>;
conjure spell putchar(mark32 c) -> mark32;

spell print(scroll msg) -> abyss {
    fore (mark16 i = 0; i < msg.len; i = i + 1) {
        putchar(msg.ptr[i]);
    }
}
spell print_ok(scroll label) -> abyss {
    print(label);
    print(" ... OK\n");
}

// --- 1. Loop Control Test ---
// Tests 'surge' (continue) and 'shatter' (break) inside a fore loop.
spell test_loops() -> mark16 {
    mark16 sum = 0;
    
    fore (mark16 i = 0; i < 10; i = i + 1) {
        if (i == 3) { surge; }   // Skip adding 3
        if (i == 7) { shatter; } // Stop completely before adding 7
        sum = sum + i;
    }
    
    // Expected sum: 0 + 1 + 2 + 4 + 5 + 6 = 18
    yield sum; 
}

// --- 2. Destined Block Test ---
// Tests that destined blocks execute in LIFO order (last in, first out)
// just before the spell yields, and conditional destined blocks respect their condition.
spell test_destined(mark16* tracker, mark16 path) -> mark16 {
    
    // BLOCK 1: Always runs. (Declared 1st, so it fires LAST)
    destined {
        *tracker = *tracker + 10;
    }

    // BLOCK 2: Conditional. (Declared 2nd, so it fires FIRST)
    destined (path == 1) {
        *tracker = *tracker + 100;
    }

    if (path == 1) {
        *tracker = 1; // Base value
        yield 99;     // Triggers Yield -> Block 2 (+100) -> Block 1 (+10) -> Returns 99
    }

    *tracker = 2; // Base value
    yield 88;     // Triggers Yield -> Block 2 (Skipped) -> Block 1 (+10) -> Returns 88
}

// --- The Test Runner ---
spell main() -> mark16 {
    print("\nRunning Test 06...\n");

    // Run Loop Test
    mark16 loop_result = test_loops();
    if (loop_result != 18) {
        print("-> FAIL: Loop test returned wrong sum.\n");
    }

    // Run Destined Test (Path 1)
    mark16 tracker_a = 0;
    mark16 ret_a = test_destined(&tracker_a, 1);
    if (ret_a != 99) { print("-> FAIL: Destined Path 1 returned wrong value.\n"); }
    if (tracker_a != 111) { print("-> FAIL: Destined Path 1 LIFO cleanup failed.\n"); } // 1 + 100 + 10 = 111

    // Run Destined Test (Path 0)
    mark16 tracker_b = 0;
    mark16 ret_b = test_destined(&tracker_b, 0);
    if (ret_b != 88) { print("-> FAIL: Destined Path 0 returned wrong value.\n"); }
    if (tracker_b != 12) { print("-> FAIL: Destined Path 0 conditional block ran when it shouldn't have.\n"); } // 2 + 10 = 12

    // Validation
    if (loop_result == 18) {
        if (tracker_a == 111) {
            if (tracker_b == 12) {
                print_ok("TEST 06: Loop Control and Destined Cleanups");
            }
        }
    }

    yield 0;
}