// 1. THE GRIMOIRE (The Include)
// This tells CodeGen to emit '#include <stdio.h>' at the top of the C file.
grimoire <stdio.h>;

// 2. THE CONJURE (The FFI Binding)
// 'conjure' tells the Semantic Analyzer: "Trust me, this spell exists in C. 
// Do not look for a body, and do not crash when I call it."
conjure spell putchar(mark32 character) -> mark32;

spell main() -> mark32 {
    
    // Print "Hi!" to the terminal using ASCII codes
    // H = 72, i = 105, ! = 33, \n = 10
    
    putchar(72);
    putchar(105);
    putchar(33);
    putchar(10); // Newline

    yield 0;
}